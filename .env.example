VITE_FIREBASE_API_KEY=
# 로컬 기본값은 project-id.firebaseapp.com입니다. HTTPS 프로덕션에서는 현재 서비스 도메인을 자동 사용합니다.
# 서비스 도메인은 Firebase Authentication 승인 도메인과 Google OAuth 리디렉션 URI에 추가해야 합니다.
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Vercel과 프론트가 같은 도메인이면 /api를 그대로 사용합니다.
VITE_BOOKING_API_URL=/api

# Vercel Functions 전용 값입니다. VITE_ 접두사를 붙이면 안 됩니다.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# 로컬 .env에서는 아래처럼 따옴표와 \n을 사용합니다.
# Vercel 대시보드에는 FIREBASE_PRIVATE_KEY= 접두사와 바깥 따옴표 없이 키 값만 입력하세요.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
ADMIN_ACCESS_PASSWORD=
ADMIN_SESSION_SECRET=
