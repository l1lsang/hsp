{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/__/auth/:path*",
      "destination": "https://hsphiway.firebaseapp.com/__/auth/:path*"
    },
    {
      "source": "/__/firebase/:path*",
      "destination": "https://hsphiway.firebaseapp.com/__/firebase/:path*"
    }
  ]
}
